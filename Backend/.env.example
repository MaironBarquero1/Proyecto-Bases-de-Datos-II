# ============================================================
# SGID LogiChain – Variables de Entorno
# Copie este archivo como .env y ajuste los valores.
# NUNCA suba el .env real al repositorio.
# ============================================================

# Puerto del servidor Express
PORT=3000

# Conexión MySQL (credenciales del pool de aplicación)
# En producción use un usuario con solo los permisos del rol_dba_sgid.
# Nota: si levanta MySQL con el Dockerfile de /SQL, el contenedor suele
# mapearse al puerto 3307 del host (DB_PORT=3307).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=SGID_LogiChain
DB_USER=crodriguez
DB_PASSWORD=MiClaveSegura123*
